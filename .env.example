# OpenAI API Key (required)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here


# PlantNet API Key (optional but recommended)
# Free key available at https://my.plantnet.org/
# Without this key, the app falls back to OpenAI vision-only identification
PLANTNET_API_KEY=your-plantnet-key-here
